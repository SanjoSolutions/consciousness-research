Cell[BoxData[{
 RowBox[{
  RowBox[{
  "consciousnessCalibrationsAtAndAbove", "[", 
   "consciousnessCalibrationLevel_", "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Select", "[", 
   RowBox[{"consciousnessCalibrations", ",", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"ListQ", "[", 
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", 
       RowBox[{
        RowBox[{"GreaterEqual", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          "consciousnessCalibrationLevel"}], "]"}], "&&", 
        RowBox[{"!", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", 
             RowBox[{"#", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "]"}], "\[GreaterEqual]", "3"}],
            "&&", 
           RowBox[{"StringStartsQ", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "[", 
              RowBox[{"[", "3", "]"}], "]"}], ",", " ", "\"\<(\>\""}], "]"}], 
           "&&", 
           RowBox[{
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "[", 
             RowBox[{"[", "1", "]"}], "]"}], "\[Equal]", 
            "consciousnessCalibrationLevel"}]}], ")"}]}]}], ",", 
       RowBox[{"GreaterEqual", "[", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ",", 
         "consciousnessCalibrationLevel"}], "]"}]}], "]"}], "&"}]}], 
