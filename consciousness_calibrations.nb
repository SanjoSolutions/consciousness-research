Cell[BoxData[
 RowBox[{
  RowBox[{"consciousnessCalibrationsAtAndAboveAndBelow", "[", 
   RowBox[{
   "consciousnessCalibrationLevelFrom_", ",", " ", 
    "consciousnessCalibrationLevelBelow_"}], " ", "]"}], ":=", 
  RowBox[{"Select", "[", 
   RowBox[{
    RowBox[{
    "consciousnessCalibrationsAtAndAbove", "[", 
     "consciousnessCalibrationLevelFrom", "]"}], ",", " ", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"ListQ", "[", 
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", 
       RowBox[{
        RowBox[{"Less", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", 
          "consciousnessCalibrationLevelBelow"}], "]"}], "&&", 
        RowBox[{"!", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", 
             RowBox[{"#", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "]"}], "\[GreaterEqual]", "3"}],
            "&&", 
           RowBox[{"StringEndsQ", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "[", 
              RowBox[{"[", "3", "]"}], "]"}], ",", " ", "\"\<)\>\""}], "]"}], 
           "&&", 
           RowBox[{
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "[", 
             RowBox[{"[", "2", "]"}], "]"}], "\[Equal]", 
            "consciousnessCalibrationLevelBelow"}]}], ")"}]}]}], ",", 
       RowBox[{"Less", "[", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ",", 
         "consciousnessCalibrationLevelBelow"}], "]"}]}], "]"}], "&"}]}], 
   "]"}]}]], "Input",
